      "source": [
        "import kagglehub\n",
        "\n",
        "#########################################################################################\n",
        "# IBM HR Analytics Employee Attrition & Performance\n",
        "# 출처 : https://www.kaggle.com/datasets/pavansubhasht/ibm-hr-analytics-attrition-dataset\n",
        "#########################################################################################\n",
        "\n",
        "path = kagglehub.dataset_download(\"pavansubhasht/ibm-hr-analytics-attrition-dataset\")\n",
        "\n",
        "df=pd.read_csv(path+'/WA_Fn-UseC_-HR-Employee-Attrition.csv',na_values=['?'])\n",
        "\n",
        "# IBM HR 데이터셋 컬럼명 매핑 사전\n",
        "hr_column_map = {\n",
        "    'Age': '나이',\n",
        "    'Attrition': '이직여부',\n",
        "    'BusinessTravel': '출장빈도',\n",
        "    'DailyRate': '일일급여수준',\n",
        "    'Department': '부서',\n",
        "    'DistanceFromHome': '출퇴근거리',\n",
        "    'Education': '교육수준',\n",
        "    'EducationField': '전공분야',\n",
        "    'EmployeeCount': '직원수',\n",
        "    'EmployeeNumber': '사원번호',\n",
        "    'EnvironmentSatisfaction': '근무환경만족도',\n",
        "    'Gender': '성별',\n",
        "    'HourlyRate': '시간당급여수준',\n",
        "    'JobInvolvement': '직무몰입도',\n",
        "    'JobLevel': '직급',\n",
        "    'JobRole': '직무역할',\n",
        "    'JobSatisfaction': '직무만족도',\n",
        "    'MaritalStatus': '결혼상태',\n",
        "    'MonthlyIncome': '월급여',\n",
        "    'MonthlyRate': '월급여수준',\n",
        "    'NumCompaniesWorked': '거쳐온회사수',\n",
        "    'Over18': '18세이상여부',\n",
        "    'OverTime': '야근여부',\n",
        "    'PercentSalaryHike': '급여인상률',\n",
        "    'PerformanceRating': '성과평가등급',\n",
        "    'RelationshipSatisfaction': '대인관계만족도',\n",
        "    'StandardHours': '표준근무시간',\n",
        "    'StockOptionLevel': '스톡옵션레벨',\n",
        "    'TotalWorkingYears': '총경력연수',\n",
        "    'TrainingTimesLastYear': '전년도교육횟수',\n",
        "    'WorkLifeBalance': '워라밸점수',\n",
        "    'YearsAtCompany': '현회사근속연수',\n",
        "    'YearsInCurrentRole': '현직무체류연수',\n",
        "    'YearsSinceLastPromotion': '마지막승진후경과연수',\n",
        "    'YearsWithCurrManager': '현팀장과함께한연수'\n",
        "}\n",
        "df = df.rename(columns=hr_column_map)\n",
        "display(df.shape)\n",
        "display(df)"
      ]
    },
    {

    {
      "cell_type": "code",
      "source": [
        "# 1. 모델 확정 (Finalize)\n",
        "# 전체 데이터셋을 사용하여 모델을 최종 학습시킵니다.\n",
        "final_model = finalize_model(blender_final)\n",
        "\n",
        "# 2. 원본 데이터로 예측 수행\n",
        "# setup에서 사용했던 원본 데이터(또는 외부 test 데이터)를 넣습니다.\n",
        "# 만약 외부 데이터를 불러왔다면 data=external_df 처럼 넣으시면 됩니다.\n",
        "predictions = predict_model(final_model, data=df_encoded) # data는 처음에 setup에 넣었던 변수명\n",
        "\n",
        "# 3. 예측 결과 상위 5개 확인\n",
        "print(\"\\n--- 예측 결과 샘플 (Label: 예측값, Score: 확율) ---\")\n",
        "print(predictions[['prediction_label', 'prediction_score']].head())\n",
        "\n",
        "# 4. (선택) 성능 리포트 확인\n",
        "# 만약 원본 데이터에 실제 정답(Target)이 포함되어 있다면 성능 지표도 출력됩니다.\n",
        "final_perf = pull()\n",
        "print(\"\\n--- 원본 데이터 기준 최종 성능 ---\")\n",
        "print(final_perf)"
      ],

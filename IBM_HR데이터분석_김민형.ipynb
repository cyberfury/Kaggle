    {
      "cell_type": "markdown",
      "source": [
        "# 5.분석용 데이터셋 추가"
      ],
      "metadata": {
        "id": "iQ9DM6kPun8-"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "#### 이직에 영향을 주는 인자를 SHAP value 로 추정 하여 고객별 값을 2가지 형태로 나눔\n",
        "#### -이직요인\n",
        "#### -이직방해요인\n"
      ],
      "metadata": {
        "id": "G6oPoY_kuvKH"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import shap\n",
        "\n",
        "# 1. SHAP 및 데이터 준비\n",
        "X_processed = get_config('X')\n",
        "feature_names = X_processed.columns\n",
        "explainer = shap.TreeExplainer(final_model.estimators_[0])\n",
        "shap_values = explainer.shap_values(X_processed)\n",
        "\n",
        "# 2. 변수명 직관화 매핑 함수\n",
        "def rename_feature(feature_name, is_push, value):\n",
        "    # 야근여부_Yes 컬럼 특수 처리\n",
        "    if feature_name == '야근여부_Yes':\n",
        "        if is_push: # 이직을 부추기는 요인일 때\n",
        "            return \"잦은 야근\"\n",
        "        else: # 이직을 막아주는 요인일 때\n",
        "            return \"야근 없는 환경\"\n",
        "\n",
        "    # 다른 주요 변수들도 한글화 (필요시 추가 가능)\n",
        "    mapping = {\n",
        "        '월급여': '급여 수준',\n",
        "        '총경력연수': '전체 경력',\n",
        "        '현회사근속연수': '장기 근속',\n",
        "        '스톡옵션레벨': '스톡옵션 혜택',\n",
        "        '현팀장과함한연수': '팀장과의 유대감',\n",
        "        '직무만족도께': '업무 만족도'\n",
        "    }\n",
        "    return mapping.get(feature_name, feature_name)\n",
        "\n",
        "# 3. 분석 함수 수정\n",
        "def extract_hr_factors_korean(idx, shap_vals, features, X_data, top_n=5):\n",
        "    emp_shap = shap_vals[idx]\n",
        "    reasons = pd.DataFrame({'Feature': features, 'SHAP': emp_shap})\n",
        "\n",
        "    # [Push Factors] 이직 원인\n",
        "    push_df = reasons[reasons['SHAP'] > 0].copy()\n",
        "    push_results = []\n",
        "    if not push_df.empty:\n",
        "        total_push = push_df['SHAP'].sum()\n",
        "        push_df['Pct'] = (push_df['SHAP'] / total_push) * 100\n",
        "        push_top = push_df.sort_values(by='Pct', ascending=False).head(top_n)\n",
        "        for i in range(top_n):\n",
        "            if i < len(push_top):\n",
        "                name = rename_feature(push_top.iloc[i]['Feature'], True, True)\n",
        "                push_results.extend([name, round(push_top.iloc[i]['Pct'], 1)])\n",
        "            else:\n",
        "                push_results.extend([\"-\", 0])\n",
        "    else:\n",
        "        push_results = [\"-\", 0, \"-\", 0, \"-\", 0]\n",
        "\n",
        "    # [Pull Factors] 방어 원인\n",
        "    pull_df = reasons[reasons['SHAP'] < 0].copy()\n",
        "    pull_results = []\n",
        "    if not pull_df.empty:\n",
        "        total_pull = pull_df['SHAP'].abs().sum()\n",
        "        pull_df['Pct'] = (pull_df['SHAP'].abs() / total_pull) * 100\n",
        "        pull_top = pull_df.sort_values(by='Pct', ascending=False).head(top_n)\n",
        "        for i in range(top_n):\n",
        "            if i < len(pull_top):\n",
        "                name = rename_feature(pull_top.iloc[i]['Feature'], False, False)\n",
        "                pull_results.extend([name, round(pull_top.iloc[i]['Pct'], 1)])\n",
        "            else:\n",
        "                pull_results.extend([\"-\", 0])\n",
        "    else:\n",
        "        pull_results = [\"-\", 0, \"-\", 0, \"-\", 0]\n",
        "\n",
        "    return push_results + pull_results\n",
        "\n",
        "# 4. 전체 데이터 적용 및 결합\n",
        "hr_analysis_korean = [extract_hr_factors_korean(i, shap_values, feature_names, X_processed) for i in range(len(X_processed))]\n",
        "\n",
        "cols = [\n",
        "    '이직원인_1', '기여도_1(%)', '이직원인_2', '기여도_2(%)', '이직원인_3', '기여도_3(%)', '이직원인_4', '기여도_4(%)', '이직원인_5', '기여도_5(%)',\n",
        "    '방어원인_1', '방어기여_1(%)', '방어원인_2', '방어기여_2(%)', '방어원인_3', '방어기여_3(%)', '방어원인_4', '방어기여_4(%)', '방어원인_5', '방어기여_5(%)'\n",
        "]\n",
        "df_hr_korean = pd.DataFrame(hr_analysis_korean, columns=cols)\n",
        "\n",
        "# 1. 계산할 대상 컬럼 리스트 정의\n",
        "push_pct_cols = ['기여도_1(%)', '기여도_2(%)', '기여도_3(%)', '기여도_4(%)', '기여도_5(%)']\n",
        "pull_pct_cols = ['방어기여_1(%)', '방어기여_2(%)', '방어기여_3(%)', '방어기여_4(%)', '방어기여_5(%)']\n",
        "\n",
        "# 2. 이직 원인(Push) 합계 계산\n",
        "df_hr_korean['이직원인_Top3_합계'] = df_hr_korean[push_pct_cols[:3]].sum(axis=1)\n",
        "df_hr_korean['이직원인_Top5_합계'] = df_hr_korean[push_pct_cols].sum(axis=1)\n",

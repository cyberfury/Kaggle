      "source": [
        "#### [설명] 트리모델 대상 최적의 결과를 탐색\n",
        "from datetime import datetime\n",
        "\n",
        "trgt_models = ['xgboost', 'rf', 'lightgbm', 'gbc', 'et'] # 앞선 모델링에서 성능 상위모델을\n",
        "tuned_models_dict = {}\n",
        "performance_data = []  # 성능 데이터를 담을 리스트\n",
        "\n",
        "# 튜닝 공통 설정\n",
        "FOLD_NUM = 5\n",
        "ITER_NUM = 50\n",
        "\n",
        "for trgt in trgt_models:\n",
        "    print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}]======= {trgt} Base 시작 =======\")\n",
        "\n",
        "    # 1. 베이스라인 모델 생성\n",
        "    base_model = create_model(trgt, fold=FOLD_NUM, verbose=False)\n",
        "    perf_base = pull()\n",
        "    performance_data.append({\n",
        "        'Model': f\"{trgt}_base\",\n",
        "        'AUC_Mean': perf_base.loc['Mean', 'AUC'],\n",
        "        'AUC_Std': perf_base.loc['Std', 'AUC'],\n",
        "        'Kappa': perf_base.loc['Mean', 'Kappa'],   # 우연성 배제 점수\n",
        "        'MCC': perf_base.loc['Mean', 'MCC'],       # 종합 상관계수\n",
        "        'F1': perf_base.loc['Mean', 'F1']          # 정밀도와 재현율의 조화\n",
        "    })\n",
        "\n",
        "    # 2. Scikit-learn (Random Search) 튜닝\n",
        "    print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}]--- {trgt} Sklearn 튜닝 중 ---\")\n",
        "    tuned_sklearn = tune_model(base_model,\n",
        "                               optimize='AUC',\n",
        "                               n_iter=ITER_NUM,\n",
        "                               fold=FOLD_NUM,\n",
        "                               choose_better=True,\n",
        "                               verbose=False)\n",
        "\n",
        "    perf_sk = pull()\n",
        "    performance_data.append({\n",
        "        'Model': f\"{trgt}_sklearn\",\n",
        "        'AUC_Mean': perf_sk.loc['Mean', 'AUC'],\n",
        "        'AUC_Std': perf_sk.loc['Std', 'AUC'],\n",
        "        'Kappa': perf_sk.loc['Mean', 'Kappa'],   # 우연성 배제 점수\n",
        "        'MCC': perf_sk.loc['Mean', 'MCC'],       # 종합 상관계수\n",
        "        'F1': perf_sk.loc['Mean', 'F1']          # 정밀도와 재현율의 조화\n",
        "    })\n",
        "    tuned_models_dict[f\"{trgt}_sklearn\"] = tuned_sklearn\n",
        "\n",
        "    # 3. Optuna 엔진 사용 + 조기 종료(Early Stopping)\n",
        "    print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}]--- {trgt} Optuna 튜닝 중 ---\")\n",
        "    tuned_optuna = tune_model(base_model,\n",
        "                              search_library='optuna',\n",
        "                              optimize='AUC',\n",
        "                              n_iter=ITER_NUM,\n",
        "                              fold=FOLD_NUM,\n",
        "                              early_stopping=True,\n",
        "                              early_stopping_max_iters=10,\n",
        "                              choose_better=True,\n",
        "                              verbose=False)\n",
        "\n",
        "    perf_optuna = pull()\n",
        "    # 모델별로 아래 데이터를 수집합니다.\n",
        "    performance_data.append({\n",
        "        'Model': f\"{trgt}_optuna\",\n",
        "        'AUC_Mean': perf_optuna.loc['Mean', 'AUC'],\n",
        "        'AUC_Std': perf_optuna.loc['Std', 'AUC'],\n",
        "        'Kappa': perf_optuna.loc['Mean', 'Kappa'],   # 우연성 배제 점수\n",
        "        'MCC': perf_optuna.loc['Mean', 'MCC'],       # 종합 상관계수\n",
        "        'F1': perf_optuna.loc['Mean', 'F1']          # 정밀도와 재현율의 조화\n",
        "    })\n",
        "    tuned_models_dict[f\"{trgt}_optuna\"] = tuned_optuna\n",
        "\n",
        "print(f\"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}]--- 종료 ---\")\n",
        "# 결과 정리 및 출력\n",
        "performance_df = pd.DataFrame(performance_data).sort_values(by='AUC_Mean', ascending=False)\n",
        "print(\"\\n--- 최종 모델 성능 순위 (안정성 포함) ---\")\n",
        "print(performance_df)"
      ]
    },

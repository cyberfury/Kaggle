    {
      "cell_type": "code",
      "source": [
        "#### [설명] 선형 모델이 상위임으로 VIF 를 통한 공선성 이슈를 점검\n",
        "from statsmodels.stats.outliers_influence import variance_inflation_factor\n",
        "\n",
        "# 1. 전처리된 학습 데이터 가져오기\n",
        "df_vif=df_encoded.drop('이직여부', axis=1)\n",
        "\n",
        "for col in df_vif.select_dtypes(include='bool').columns:\n",
        "    df_vif[col] = df_vif[col].astype(int)\n",
        "\n",
        "# 2. VIF 계산 (수치형 변수들에 대해 수행)\n",
        "vif_data = pd.DataFrame()\n",
        "vif_data[\"feature\"] = df_vif.columns\n",
        "\n",
        "# 각 변수별 VIF 계산\n",
        "vif_data[\"VIF\"] = [variance_inflation_factor(df_vif.values, i) for i in range(len(df_vif.columns))]\n",
        "\n",
        "# 3. VIF가 높은 순서대로 정렬 (보통 5~10 이상이면 위험군)\n",
        "display(vif_data.sort_values(by=\"VIF\", ascending=False))"
      ],
